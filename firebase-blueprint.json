{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (Mentor, Tutor, or Team Leader)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["mentor", "tutor", "team_leader"] },
        "name": { "type": "string" },
        "tutorId": { "type": "string", "description": "ID for tutors" },
        "isResigned": { "type": "boolean" },
        "teamLeaderName": { "type": "string" },
        "teamNumber": { "type": "string" },
        "subTeamName": { "type": "string" },
        "mentorId": { "type": "string" },
        "mentorName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "TutorDetails": {
      "title": "TutorDetails",
      "description": "Detailed information for a tutor",
      "type": "object",
      "properties": {
        "tutorId": { "type": "string" },
        "name": { "type": "string" },
        "studyPlan": {
          "type": "object",
          "properties": {
            "course1": { "type": "string" },
            "course1Grade": { "type": "string" },
            "course2": { "type": "string" },
            "course2Grade": { "type": "string" },
            "notes": { "type": "string" },
            "materialLink": { "type": "string" }
          }
        },
        "performance": {
          "type": "object",
          "properties": {
            "quality": { "type": "number" },
            "work": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "status": { "type": "string", "enum": ["active", "resigned"] }
      }
    },
    "Vacation": {
      "title": "Vacation",
      "description": "A vacation record",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "QualityReport": {
      "title": "QualityReport",
      "description": "A monthly quality report",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "percentage": { "type": "number" },
        "meetingDate": { "type": "string" },
        "meetingLink": { "type": "string" },
        "recordedLink": { "type": "string" },
        "postMeetingNotes": { "type": "string" },
        "reportUrl": { "type": "string" }
      }
    },
    "Flag": {
      "title": "Flag",
      "description": "A performance flag",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["red", "yellow"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["done", "cancel", "in progress"] },
        "tutorFeedback": { "type": "string" },
        "mentorFeedback": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "Course": {
      "title": "Course",
      "description": "A course studied by a tutor",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "grade": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users": {
      "schema": "User",
      "description": "All users in the system"
    },
    "/tutors/{tutorId}": {
      "schema": "TutorDetails",
      "description": "Details for a specific tutor"
    },
    "/tutors/{tutorId}/vacations": {
      "schema": "Vacation",
      "description": "Vacations for a tutor"
    },
    "/tutors/{tutorId}/qualityReports": {
      "schema": "QualityReport",
      "description": "Quality reports for a tutor"
    },
    "/tutors/{tutorId}/flags": {
      "schema": "Flag",
      "description": "Flags for a tutor"
    },
    "/tutors/{tutorId}/courses": {
      "schema": "Course",
      "description": "Courses studied by a tutor"
    }
  }
}
